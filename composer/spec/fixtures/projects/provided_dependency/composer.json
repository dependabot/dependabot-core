{
    "name": "dependabot/provides",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=7.1",
        "php-http/client-implementation": "^1.0"
    },
    "require-dev": {
        "dependabot/client-implementation-provider": "^1.0"
    },
    "repositories": [
        {
            "type": "path",
            "url": "./local-deps/client-implementation",
            "options": {
                "symlink": false
            }
        }
    ],
    "minimum-stability": "stable"
}
