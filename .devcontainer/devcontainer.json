{
  "name": "Cosmicjuan-Ecosystem-Core",
  "build": {
    "dockerfile": "Dockerfile",
    "args": { "VARIANT": "ubuntu-22.04" }
  },
  "features": {
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": "latest",
    "ghcr.io/devcontainers/features/node:1": "lts",
    "ghcr.io/devcontainers/features/ruby:1": "3.4.8"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "nomicfoundation.hardhat-solidity",
        "ms-vscode.cpptools",
        "formulahendry.terminal",
        "stkb.rewrap"
      ],
      "settings": {
        "editor.tabSize": 2,
        "editor.formatOnSave": true,
        "editor.insertSpaces": true,
        "editor.precision": "high",
        "solidity.compileAfterSave": true,
        "ruby.lsp.enabled": true
      }
    }
  },
  "remoteUser": "vscode",
  "onCreateCommand": "bash .devcontainer/on-create.sh",
  "postCreateCommand": "gpg --import ~/Red-62-Ruta-62/node-config/BC4A5D704CC5D513.asc && git config --global user.signingkey BC4A5D704CC5D513"
}
