{
  "job": {
    "command": "version",
    "allowed-updates": [
      {
        "dependency-type": "direct",
        "update-type": "all"
      }
    ],
    "commit-message-options": {
      "prefix": null,
      "prefix-development": null,
      "include-scope": null
    },
    "credentials-metadata": [
      { "type": "git_source", "host": "github.com" },
      { "type": "maven_repository", "url": "https://maven.google.com" },
      { "type": "maven_repository", "url": "https://plugins.gradle.org/m2" },
      { "type": "maven_repository", "url": "https://repo.maven.apache.org/maven2" }
    ],
    "debug": null,
    "dependencies": null,

    "dependency-groups": [
      { "name": "kotlin", "rules": { "patterns": ["org.jetbrains.kotlin*", "org.jetbrains.kotlinx*"] } },
      { "name": "compose", "rules": { "patterns": ["androidx.compose*", "androidx.activity:activity-compose"] } },
      { "name": "firebase", "rules": { "patterns": ["com.google.firebase*", "com.google.gms*"] } },
      { "name": "media3", "rules": { "patterns": ["androidx.media3*"] } },
      { "name": "koin", "rules": { "patterns": ["io.insert-koin*"] } },
      { "name": "coil", "rules": { "patterns": ["io.coil-kt.coil3*"] } },
      { "name": "retrofit-okhttp", "rules": { "patterns": ["com.squareup.retrofit2*", "com.squareup.okhttp3*"] } },
      { "name": "detekt", "rules": { "patterns": ["io.gitlab.arturbosch.detekt*"] } },
      { "name": "mockk", "rules": { "patterns": ["io.mockk*"] } },
      { "name": "junit", "rules": { "patterns": ["org.junit*", "junit:junit"] } },
      { "name": "dokka", "rules": { "patterns": ["org.jetbrains.dokka*"] } },
      { "name": "androidx-lifecycle", "rules": { "patterns": ["androidx.lifecycle*"] } },
      { "name": "androidx-navigation", "rules": { "patterns": ["androidx.navigation*"] } },
      {
        "name": "android-build-tools",
        "rules": {
          "patterns": [
            "com.android.tools.build*",
            "com.android.settings*",
            "com.android.application*",
            "com.android.library*",
            "com.android.lint*"
          ]
        }
      }
    ],

    "dependency-group-to-refresh": null,
    "existing-pull-requests": [],
    "existing-group-pull-requests": [],

    "experiments": {
      "record-ecosystem-versions": true,
      "record-update-job-unknown-error": true,
      "proxy-cached": true,
      "enable-corepack-for-npm-and-yarn": true,
      "enable-private-registry-for-corepack": true,
      "allow-refresh-for-existing-pr-dependencies": true,
      "allow-refresh-group-with-all-dependencies": true,
      "azure-registry-backup": true,
      "enable-enhanced-error-details-for-updater": true,
      "gradle-lockfile-updater": true,
      "enable-exclude-paths-subdirectory-manifest-files": true,
      "blocked-versions": true,
      "workflow-job-summary": true,
      "async-retry": true,
      "enable-npmrc-credential-generation": true,
      "enable-cooldown-default-days": true
    },

    "ignore-conditions": [],
    "lockfile-only": false,
    "max-updater-run-time": 2700,
    "package-manager": "gradle",
    "requirements-update-strategy": null,
    "reject-external-code": false,
    "security-advisories": [],
    "security-updates-only": false,

    "source": {
      "provider": "github",
      "repo": "thavaahariharangit/cxone-mobile-sdk-android",
      "branch": "develop",
      "directory": "/.",
      "api-endpoint": "https://api.github.com/",
      "hostname": "github.com"
    },

    "updating-a-pull-request": false,
    "update-subdependencies": false,
    "vendor-dependencies": false,
    "enable-beta-ecosystems": false,
    "repo-private": true,
    "multi-ecosystem-update": false,
    "exclude-paths": null
  }
}
