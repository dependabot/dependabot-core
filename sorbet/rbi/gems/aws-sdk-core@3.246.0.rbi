# @api private
#
# pkg:gem/aws-sdk-core#lib/aws-sdk-core/plugins/regional_endpoint.rb:6
class Aws::Plugins::RegionalEndpoint < ::Seahorse::Client::Plugin
  # pkg:gem/aws-sdk-core#lib/aws-sdk-core/plugins/regional_endpoint.rb:82
  def after_initialize(client); end

  private

  # pkg:gem/aws-sdk-core#lib/aws-sdk-core/plugins/regional_endpoint.rb:101
  def initialize_default_endpoint(client); end

  # set a default endpoint in config using legacy (endpoints.json) resolver
  #
  # pkg:gem/aws-sdk-core#lib/aws-sdk-core/plugins/regional_endpoint.rb:114
  def resolve_legacy_endpoint(cfg); end

  class << self
    private

    # pkg:gem/aws-sdk-core#lib/aws-sdk-core/plugins/regional_endpoint.rb:211
    def env_global_endpoint(cfg); end

    # pkg:gem/aws-sdk-core#lib/aws-sdk-core/plugins/regional_endpoint.rb:201
    def env_service_endpoint(cfg); end

    # pkg:gem/aws-sdk-core#lib/aws-sdk-core/plugins/regional_endpoint.rb:235
    def handle_legacy_pseudo_regions(cfg); end

    # get a custom configured endpoint from ENV or configuration
    #
    # pkg:gem/aws-sdk-core#lib/aws-sdk-core/plugins/regional_endpoint.rb:194
    def resolve_custom_config_endpoint(cfg); end

    # NOTE: with Endpoints 2.0, some of this logic is deprecated
    # but because new old service gems may depend on new core versions
    # we must preserve that behavior.
    # Additional behavior controls the setting of the custom SDK::Endpoint
    # parameter.
    # When the `regional_endpoint` config is set to true - this indicates to
    # Endpoints2.0 that a custom endpoint has NOT been configured by the user.
    #
    # pkg:gem/aws-sdk-core#lib/aws-sdk-core/plugins/regional_endpoint.rb:176
    def resolve_endpoint(cfg); end

    # pkg:gem/aws-sdk-core#lib/aws-sdk-core/plugins/regional_endpoint.rb:163
    def resolve_ignore_configured_endpoint_urls(cfg); end

    # pkg:gem/aws-sdk-core#lib/aws-sdk-core/plugins/regional_endpoint.rb:135
    def resolve_region(cfg); end

    # pkg:gem/aws-sdk-core#lib/aws-sdk-core/plugins/regional_endpoint.rb:143
    def resolve_sigv4a_signing_region_set(cfg); end

    # pkg:gem/aws-sdk-core#lib/aws-sdk-core/plugins/regional_endpoint.rb:149
    def resolve_use_dualstack_endpoint(cfg); end

    # pkg:gem/aws-sdk-core#lib/aws-sdk-core/plugins/regional_endpoint.rb:157
    def resolve_use_fips_endpoint(cfg); end

    # pkg:gem/aws-sdk-core#lib/aws-sdk-core/plugins/regional_endpoint.rb:219
    def shared_config_endpoint(cfg); end

    # check region is a valid RFC host label
    #
    # pkg:gem/aws-sdk-core#lib/aws-sdk-core/plugins/regional_endpoint.rb:229
    def validate_region!(region); end
  end
end

