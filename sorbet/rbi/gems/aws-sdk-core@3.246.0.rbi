  #   resp.token_output.id_token #=> String
  #
  # @see http://docs.aws.amazon.com/goto/WebAPI/signin-2023-01-01/CreateOAuth2Token AWS API Documentation
  #
  # @overload create_o_auth_2_token(params = {})
