  #     #=> raises Aws::S3::Errors::NotFound
  #
  #     resp = client.head_object(bucket:'aws-sdk', key:'foo')
  #     resp.content_length #=> 150
  #
  # @param [Symbol] operation_name
  #
  # @param [Mixed] stubs One or more responses to return from the named
  #   operation.
