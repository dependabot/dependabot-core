  private

  # pkg:gem/rake#lib/rake/invocation_chain.rb:34
  def prefix; end

  class << self
    # Class level append.
    #
    # pkg:gem/rake#lib/rake/invocation_chain.rb:28
    def append(invocation, chain); end
  end
end

