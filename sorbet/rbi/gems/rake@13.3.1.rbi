# Polylithic linked list structure used to implement several data
# structures in Rake.
#
# pkg:gem/rake#lib/rake/linked_list.rb:6
class Rake::LinkedList
  include ::Enumerable

  # pkg:gem/rake#lib/rake/linked_list.rb:84
