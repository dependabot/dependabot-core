# @api private
#
# pkg:gem/jmespath#lib/jmespath/token_stream.rb:4
class JMESPath::TokenStream
  # @param [String<JMESPath>] expression
  # @param [Array<Token>] tokens
  #
  # pkg:gem/jmespath#lib/jmespath/token_stream.rb:7
  def initialize(expression, tokens); end

  # @return [String<JMESPath>]
  #
  # pkg:gem/jmespath#lib/jmespath/token_stream.rb:16
  def expression; end

  # @api private
  #
  # pkg:gem/jmespath#lib/jmespath/token_stream.rb:35
  def inspect; end

  # pkg:gem/jmespath#lib/jmespath/token_stream.rb:30
  def lookahead(count); end

  # @option options [Array<Symbol>] :match Requires the next token to be
  #   one of the given symbols or an error is raised.
  #
  # pkg:gem/jmespath#lib/jmespath/token_stream.rb:26
  def next(options = T.unsafe(nil)); end

  # @return [Integer]
  #
  # pkg:gem/jmespath#lib/jmespath/token_stream.rb:22
  def position; end

  # @return [Token]
  #
  # pkg:gem/jmespath#lib/jmespath/token_stream.rb:19
