# pkg:gem/jmespath#lib/jmespath/parser.rb:6
class JMESPath::Parser
  # @option options [Lexer] :lexer
  #
  # pkg:gem/jmespath#lib/jmespath/parser.rb:30
  def initialize(options = T.unsafe(nil)); end

  # @api private
  #
  # pkg:gem/jmespath#lib/jmespath/parser.rb:48
  def method_missing(method_name, *args); end

  # @param [String<JMESPath>] expression
  #
  # pkg:gem/jmespath#lib/jmespath/parser.rb:36
  def parse(expression); end

  private

  # @param [TokenStream] stream
  # @param [Integer] rbp Right binding power
  #
  # pkg:gem/jmespath#lib/jmespath/parser.rb:60
  def expr(stream, rbp = T.unsafe(nil)); end

  # pkg:gem/jmespath#lib/jmespath/parser.rb:230
  def led_and(stream, left); end

  # pkg:gem/jmespath#lib/jmespath/parser.rb:160
  def led_comparator(stream, left); end

  # pkg:gem/jmespath#lib/jmespath/parser.rb:167
  def led_dot(stream, left); end

  # pkg:gem/jmespath#lib/jmespath/parser.rb:177
  def led_filter(stream, left); end

  # pkg:gem/jmespath#lib/jmespath/parser.rb:190
  def led_flatten(stream, left); end

  # pkg:gem/jmespath#lib/jmespath/parser.rb:197
  def led_lbracket(stream, left); end

  # pkg:gem/jmespath#lib/jmespath/parser.rb:208
  def led_lparen(stream, left); end

  # pkg:gem/jmespath#lib/jmespath/parser.rb:224
  def led_or(stream, left); end

  # pkg:gem/jmespath#lib/jmespath/parser.rb:236
  def led_pipe(stream, left); end

  # pkg:gem/jmespath#lib/jmespath/parser.rb:68
  def nud_current(stream); end

  # pkg:gem/jmespath#lib/jmespath/parser.rb:73
  def nud_expref(stream); end

  # pkg:gem/jmespath#lib/jmespath/parser.rb:93
  def nud_filter(stream); end

  # pkg:gem/jmespath#lib/jmespath/parser.rb:97
  def nud_flatten(stream); end

  # pkg:gem/jmespath#lib/jmespath/parser.rb:101
  def nud_identifier(stream); end

  # pkg:gem/jmespath#lib/jmespath/parser.rb:111
  def nud_lbrace(stream); end

  # pkg:gem/jmespath#lib/jmespath/parser.rb:123
  def nud_lbracket(stream); end

  # pkg:gem/jmespath#lib/jmespath/parser.rb:135
  def nud_literal(stream); end

  # pkg:gem/jmespath#lib/jmespath/parser.rb:83
  def nud_lparen(stream); end

  # pkg:gem/jmespath#lib/jmespath/parser.rb:78
  def nud_not(stream); end

  # pkg:gem/jmespath#lib/jmespath/parser.rb:141
  def nud_quoted_identifier(stream); end

  # pkg:gem/jmespath#lib/jmespath/parser.rb:152
  def nud_star(stream); end

  # pkg:gem/jmespath#lib/jmespath/parser.rb:156
  def nud_unknown(stream); end

  # parse array index expressions, for example [0], [1:2:3], etc.
  #
  # pkg:gem/jmespath#lib/jmespath/parser.rb:243
  def parse_array_index_expression(stream); end

  # pkg:gem/jmespath#lib/jmespath/parser.rb:274
  def parse_dot(stream, binding_power); end

  # pkg:gem/jmespath#lib/jmespath/parser.rb:283
  def parse_key_value_pair(stream); end

  # pkg:gem/jmespath#lib/jmespath/parser.rb:290
