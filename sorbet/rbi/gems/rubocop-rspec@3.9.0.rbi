#     .and change(Foo, :baz).by(0)
#   expect { run }
#     .to change { Foo.bar }.by(0)
#     .and change { Foo.baz }.by(0)
#
#   # good
#   define_negated_matcher :not_change, :change
#   expect { run }
#     .to not_change(Foo, :bar)
