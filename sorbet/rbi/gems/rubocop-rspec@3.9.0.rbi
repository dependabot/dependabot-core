# and works with `--auto-gen-config`.
#
# @example
#   # bad
#   describe UserCreator do
#     it 'builds a user' do
#       expect(user.name).to eq("John")
#       expect(user.age).to eq(22)
#     end
#   end
#
#   # good
#   describe UserCreator do
#     it 'sets the users name' do
#       expect(user.name).to eq("John")
#     end
#
#     it 'sets the users age' do
#       expect(user.age).to eq(22)
#     end
#   end
#
