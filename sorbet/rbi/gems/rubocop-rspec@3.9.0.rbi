#   let(:item_2) { create(:item) }
#
#   let(:item1) { create(:item) }
#   let(:item2) { create(:item) }
#
#   # good
#
#   let(:visible_item) { create(:item, visible: true) }
#   let(:invisible_item) { create(:item, visible: false) }
#
