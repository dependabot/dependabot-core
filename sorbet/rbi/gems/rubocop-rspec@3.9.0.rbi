#   # Detected as an offense
#   describe UserCreator do
#     it 'builds a user', aggregate_failures: false do
#       expect(user.name).to eq("John")
#       expect(user.age).to eq(22)
#     end
#   end
#
# @example `Max: 1` (default)
#   # bad
#   describe UserCreator do
#     it 'builds a user' do
#       expect(user.name).to eq("John")
#       expect(user.age).to eq(22)
#     end
#   end
#
# @example `Max: 2`
#   # good
#   describe UserCreator do
#     it 'builds a user' do
#       expect(user.name).to eq("John")
#       expect(user.age).to eq(22)
#     end
#   end
#
