  # @return [Array(Integer, Hash, #each)] the rack response
  #
  # pkg:gem/vcr#lib/vcr/middleware/rack.rb:62
  def call(env); end

  private

  # pkg:gem/vcr#lib/vcr/middleware/rack.rb:72
  def cassette_arguments(env); end
end

