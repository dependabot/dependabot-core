  def to_a; end
end

# Common functionality for nodes that can be used as hash elements:
# `pair`, `kwsplat`
#
# pkg:gem/rubocop-ast#lib/rubocop/ast/node/mixin/hash_element_node.rb:7
module RuboCop::AST::HashElementNode
