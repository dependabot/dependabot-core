  def names; end

  # pkg:gem/rubocop-ast#lib/rubocop/ast/node/masgn_node.rb:42
  def rhs; end

  # In contrast to `expression`, `values` always returns a Ruby array
  # containing all the nodes being assigned on the RHS.
