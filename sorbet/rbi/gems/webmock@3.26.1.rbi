# pkg:gem/webmock#lib/webmock/version.rb:4
WebMock::VERSION = T.let(T.unsafe(nil), String)

# pkg:gem/webmock#lib/webmock/util/version_checker.rb:28
class WebMock::VersionChecker
  # pkg:gem/webmock#lib/webmock/util/version_checker.rb:29
  def initialize(library_name, library_version, min_patch_level, max_minor_version = T.unsafe(nil), unsupported_versions = T.unsafe(nil)); end

  # pkg:gem/webmock#lib/webmock/util/version_checker.rb:45
  def check_version!; end

  private

  # pkg:gem/webmock#lib/webmock/util/version_checker.rb:109
  def colorize(text, color_code); end

  # pkg:gem/webmock#lib/webmock/util/version_checker.rb:86
  def compare_version; end

  # pkg:gem/webmock#lib/webmock/util/version_checker.rb:105
  def parse_version(version); end

  # pkg:gem/webmock#lib/webmock/util/version_checker.rb:57
  def too_high?; end

  # pkg:gem/webmock#lib/webmock/util/version_checker.rb:53
  def too_low?; end

  # pkg:gem/webmock#lib/webmock/util/version_checker.rb:61
  def unsupported_version?; end

  # pkg:gem/webmock#lib/webmock/util/version_checker.rb:98
  def version_requirement; end

  # pkg:gem/webmock#lib/webmock/util/version_checker.rb:70
  def warn_about_too_high; end

  # pkg:gem/webmock#lib/webmock/util/version_checker.rb:65
  def warn_about_too_low; end

  # pkg:gem/webmock#lib/webmock/util/version_checker.rb:76
  def warn_about_unsupported_version; end

  # pkg:gem/webmock#lib/webmock/util/version_checker.rb:82
  def warn_in_red(text); end
end
