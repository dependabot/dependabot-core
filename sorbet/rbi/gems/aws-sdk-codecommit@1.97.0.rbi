  #   })
  #
  # @see http://docs.aws.amazon.com/goto/WebAPI/codecommit-2015-04-13/AssociateApprovalRuleTemplateWithRepository AWS API Documentation
  #
  # @overload associate_approval_rule_template_with_repository(params = {})
