    # pkg:gem/faraday#lib/faraday/encoders/flat_params_encoder.rb:99
    def sort_params=(_arg0); end

    # pkg:gem/faraday#lib/faraday/encoders/flat_params_encoder.rb:9
    def unescape(*args, **_arg1, &block); end
  end
end

