  # pkg:gem/rspec-core#lib/rspec/core/example.rb:412
  def set_exception(exception); end

  # pkg:gem/rspec-core#lib/rspec/core/example.rb:49
  def skip; end

  # @private
  #
  # Used internally to skip without actually executing the example when
