#!/usr/bin/env bash

set -ex

if [ -z "$DEPENDABOT_NATIVE_HELPERS_PATH" ]; then
  echo "Unable to build, DEPENDABOT_NATIVE_HELPERS_PATH is not set"
  exit 1
fi

install_dir="$DEPENDABOT_NATIVE_HELPERS_PATH/hex"
mkdir -p "$install_dir"

mix local.hex "$HEX_VERSION" --force --if-missing

# Install deps necessary for Elixir projects using Nerves extensions
# The `hex` arg isn't re-installing hex, but rather telling
# mix that nerves_bootstrap is a hex package.
mix archive.install hex nerves_bootstrap --force

helpers_dir="$(dirname "${BASH_SOURCE[0]}")"

cd "$helpers_dir"

mix deps.get
MIX_ENV=prod mix release dependabot_hex --overwrite

cp -r "_build/prod/rel/dependabot_hex" "$install_dir/release"

cat > "$install_dir/dependabot_hex" <<'EOF'
#!/bin/sh
exec "$(dirname "$0")/release/bin/dependabot_hex" start
EOF
chmod +x "$install_dir/dependabot_hex"
